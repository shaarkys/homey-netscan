{
    "name": {
        "en": "IP address",
        "nl": "IP adres",
    	"de": "IP-Adresse"
    },
    "platforms": [
        "local"
    ],
    "connectivity": [
        "lan"
    ],
    "class": "sensor",
    "capabilities": [
        "reachable",
        "alarm_offline",
        "onoff"
    ],
    "capabilitiesOptions": {
        "reachable": {
            "titleTrue": {
                "en": "Reachable",
                "nl": "Bereikbaar",
                "de": "Erreichbar"
            },
            "titleFalse": {
                "en": "Not reachable",
                "nl": "Niet bereikbaar",
                "de": "Nicht erreichbar"
            }
        },
        "alarm_offline": {
            "titleTrue": {
                "en": "Offline",
                "nl": "Offline",
                "de": "Offline"
            },
            "titleFalse": {
                "en": "Online",
                "nl": "Online",
                "de": "Online"
            },
            "uiComponent": null,
            "preventInsights": true
        },
        "onoff": {
            "uiComponent": null,
            "preventInsights": true,
            "getable": true,
            "setable": false
        }
    },
    "images": {
        "large": "assets/drivers/ip_driver/large.png",
        "small": "assets/drivers/ip_driver/small.png"
    },
    "pair": [
        {
            "id": "configure_ip"
        }
    ],
    "settings": [
        {
            "type": "group",
            "label": {
                "en": "IP address settings",
                "nl": "IP adres instellingen",
        	"de": "IP-Adresseinstellungen"
            },
            "children": [
                {
                    "id": "host",
                    "hint": {
                        "en": "IP address of the device to check",
                        "nl": "IP-adres van het te controleren apparaat",
                        "de": "IP-Adresse des zu überprüfenden Geräts"
                    },
                    "type": "text",
                    "value": "0.0.0.0",
                    "label": {
                        "en": "IP address",
                        "nl": "IP adres",
                        "de": "IP-Adresse"
                    }
                },
                {
                    "id": "probe_method",
                    "hint": {
                        "en": "Automatic uses ARP first and falls back to the legacy TCP response check.",
                        "nl": "Automatisch gebruikt eerst ARP en valt terug op de bestaande TCP-responscontrole.",
                        "de": "Automatisch verwendet zuerst ARP und greift dann auf die bisherige TCP-Antwortprüfung zurück."
                    },
                    "type": "dropdown",
                    "value": "tcp",
                    "label": {
                        "en": "Detection method",
                        "nl": "Detectiemethode",
                        "de": "Erkennungsmethode"
                    },
                    "values": [
                        {
                            "id": "automatic",
                            "label": {
                                "en": "Automatic (ARP, then TCP)",
                                "nl": "Automatisch (ARP, daarna TCP)",
                                "de": "Automatisch (ARP, dann TCP)"
                            }
                        },
                        {
                            "id": "arp",
                            "label": {
                                "en": "ARP (local IPv4 only)",
                                "nl": "ARP (alleen lokaal IPv4)",
                                "de": "ARP (nur lokales IPv4)"
                            }
                        },
                        {
                            "id": "tcp",
                            "label": {
                                "en": "TCP response (legacy)",
                                "nl": "TCP-respons (bestaand)",
                                "de": "TCP-Antwort (bisherig)"
                            }
                        }
                    ]
                },
                {
                    "id": "host_check_interval",
                    "hint": "Time between checks for the device",
                    "type": "number",
                    "value": 15,
                    "min": 15,
                    "units": "seconds",
                    "label": {
                        "en": "Check Interval",
                	"nl": "Controleer interval",
                	"de": "Prüfintervall"
                    }
                },
                {
                    "id": "host_timeout",
                    "hint": "Time to wait before reporting the device is offline",
                    "type": "number",
                    "value": 10,
                    "min": 10,
                    "units": "seconds",
                    "label": {
                        "en": "Check Timeout",
                	"nl": "Controleer time-out",
                	"de": "Zeitüberschreitung"
                    }
                },
                {
                    "id": "host_unreachable_checks",
                    "hint": "Number of unreachable failures before reporting the device is offline",
                    "type": "number",
                    "value": 1,
                    "min": 1,
                    "label": {
                        "en": "Unreachable checks",
                        "nl": "Onbereikbare controles",
                        "de": "Anzahl Erreichbarkeits-Prüfungen"
                    }
                }
            ]
        }
    ]
}
